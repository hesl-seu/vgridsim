{
    "grid_model": "ieee33",
    "solver": "gurobi",
    "start_hour": 0,
    "end_hour": 23,
    "step_minutes": 60,
    "use_pv": true,
    "use_wind": true,
    "use_ess": true,
    "use_sop": true,
    "use_nop": true,
    "ev_data_source": "random",
    "ev_params": {
        "capacity_kwh": 70.0,
        "max_charge_kw": 60.0,
        "max_discharge_kw": 25.0,
        "charge_efficiency": 0.95,
        "discharge_efficiency": 0.9
    },
    "rl_common": {
        "learning_rate": 0.0003,
        "gamma": 0.991,
        "batch_size": 256
    },
    "rl_specific": {
        "PPO": {
            "clip_range": 0.2,
            "ent_coef": 0.0
        },
        "SAC": {
            "tau": 0.005,
            "ent_coef": 0.1
        },
        "DDPG": {
            "tau": 0.005,
            "action_noise": 0.1
        },
        "TD3": {
            "policy_delay": 2,
            "target_policy_noise": 0.2
        }
    },
    "reward_weights": {
        "ev_kwh_shortage_penalty": -100.0,
        "voltage_violation_penalty": -100.0,
        "cost_penalty_factor": 1.0,
        "opendss_failure_penalty": -5000.0
    },
    "reward_mode": "grid_operator",
    "station_operator": {
        "charge_service_price": 1.2,
        "v2g_subsidy_price": 0.8,
        "include_grid_cost": true,
        "include_generation_cost": true,
        "include_ess_cost": true,
        "include_sop_loss_cost": true,
        "include_penalty_cost": true
    }
}